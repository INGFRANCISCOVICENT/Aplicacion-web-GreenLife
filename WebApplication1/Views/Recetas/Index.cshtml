<div class="welcome-hero">
    <div class="glass-overlay"></div>
    <div class="welcome-content">
        <div class="badge-vegan">🌱 100% Plant-Based</div>
        <h1 class="hero-title">Discover the Art of <span class="brand-name">Vegan Cuisine</span></h1>
        <p class="hero-subtitle">Embark on a journey to a healthier, cruelty-free lifestyle. Delicious recipes, expertly crafted for your well-being.</p>
        
        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="auth-buttons mt-4">
                <a asp-controller="Account" asp-action="Login" class="btn-custom btn-primary-glass">
                    <i class="fas fa-sign-in-alt me-2"></i>Iniciar Sesión
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn-custom btn-secondary-glass">
                    <i class="fas fa-user-plus me-2"></i>Registrarse
                </a>
            </div>
        }
        else
        {
            <div class="auth-buttons mt-4">
                <a asp-controller="Recetas" asp-action="Menu" class="btn-custom btn-primary-glass">
                    <i class="fas fa-utensils me-2"></i>Explorar Menú
                </a>
            </div>
        }
    </div>
</div>

