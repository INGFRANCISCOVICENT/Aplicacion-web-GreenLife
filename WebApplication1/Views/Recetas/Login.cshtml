<div class="login-page">
    <div class="login-card">
        <div class="login-brand">GreenLife</div>
        <h2 class="login-title">Iniciar Sesión</h2>
        <form asp-action="Menu" method="get" class="login-form">
            <div class="form-group">
                <label for="user">Usuario</label>
                <input id="user" name="user" type="text" class="form-input" placeholder="Ingrese su usuario" required />
            </div>
            <div class="form-group">
                <label for="pass">Contraseña</label>
                <input id="pass" name="pass" type="password" class="form-input" placeholder="Ingrese su contraseña" required />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-login">Entrar</button>
                <a asp-action="Register" class="btn btn-register">Registrarse</a>
                <a asp-action="Index" class="btn btn-link btn-back">Volver al inicio</a>
            </div>
        </form>

        <div class="social-login-container">
            <div class="social-login-divider">
                <span>O continuar con</span>
            </div>
            <button type="button" class="btn-social btn-social-google" onclick="simulateSocialAuth('Google', this)">
                <i class="fab fa-google text-danger"></i>
                <span class="ms-2">Google</span>
            </button>
            <button type="button" class="btn-social btn-social-apple" onclick="simulateSocialAuth('Apple', this)">
                <i class="fab fa-apple"></i>
                <span class="ms-2">Apple</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function simulateSocialAuth(provider, btnElement) {
            // Guardar contenido original
            const originalHtml = btnElement.innerHTML;
            
            // Mostrar estado de carga
            btnElement.innerHTML = `<i class="fas fa-spinner fa-spin"></i><span class="ms-2">Conectando con ${provider}...</span>`;
            btnElement.disabled = true;
            
            // Simular retraso de red
            setTimeout(() => {
                alert(`[Simulación] Inicio de sesión exitoso con tu cuenta de ${provider}.`);
                // Restaurar estado del botón
                btnElement.innerHTML = originalHtml;
                btnElement.disabled = false;
            }, 1200);
        }
    </script>
}
