@model WebApplication1.Models.Usuario
@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="login-page">
    <div class="login-card">
        <div class="text-center mb-4">
            <i class="fas fa-user-plus text-success fa-3x mb-3"></i>
            <h1 class="login-brand">Únete a GreenLife</h1>
            <p class="login-title">Registra tu cuenta y comienza a cocinar vegano</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Register" method="post">
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="form-label">Nombre Completo</label>
                <input asp-for="Nombre" class="form-input" placeholder="Tu nombre artístico" required />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-input" placeholder="ejemplo@correo.com" required />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="form-group mb-4">
                <label for="password" class="form-label">Contraseña</label>
                <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
            </div>
            <div class="d-grid mb-3">
                <button type="submit" class="btn-auth">Registrarse y Entrar</button>
            </div>
        </form>

        <div class="social-login-container">
            <div class="social-login-divider">
                <span>O continuar con</span>
            </div>
            <button type="button" class="btn-social btn-social-google" onclick="simulateSocialAuth('Google', this)">
                <i class="fab fa-google text-danger"></i>
                <span class="ms-2">Google</span>
            </button>
            <button type="button" class="btn-social btn-social-apple" onclick="simulateSocialAuth('Apple', this)">
                <i class="fab fa-apple"></i>
                <span class="ms-2">Apple</span>
            </button>
        </div>

        <div class="text-center mt-4 pt-3 border-top">
            <p class="mb-0 text-muted">¿Ya tienes cuenta? <a asp-action="Login" class="footer-link">Inicia sesión aquí</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function simulateSocialAuth(provider, btnElement) {
            // Save original content
            const originalHtml = btnElement.innerHTML;
            
            // Show loading state
            btnElement.innerHTML = `<i class="fas fa-spinner fa-spin"></i><span class="ms-2">Conectando con ${provider}...</span>`;
            btnElement.disabled = true;
            
            // Simulate network delay
            setTimeout(() => {
                alert(`[Simulación] Registro exitoso con tu cuenta de ${provider}.`);
                // Restore button state
                btnElement.innerHTML = originalHtml;
                btnElement.disabled = false;
            }, 1500);
        }
    </script>
}
