@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="login-page">
    <div class="login-card">
        <div class="text-center mb-4">
            <i class="fas fa-leaf text-success fa-3x mb-3"></i>
            <h1 class="login-brand">Bienvenido de nuevo</h1>
            <p class="login-title">Ingresa a tu cuenta de GreenLife</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i> @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">
            <div class="form-group mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="ejemplo@correo.com" required />
            </div>
            <div class="form-group mb-4">
                <label for="password" class="form-label">Contraseña</label>
                <input type="password" id="password" name="password" class="form-input" placeholder="••••••••" required />
            </div>
            <div class="d-grid mb-3">
                <button type="submit" class="btn-auth">Iniciar Sesión</button>
            </div>
        </form>

        <div class="text-center mt-4 pt-3 border-top">
            <p class="mb-0 text-muted">¿No tienes cuenta? <a asp-action="Register" class="footer-link">Regístrate aquí</a></p>
        </div>
    </div>
</div>
